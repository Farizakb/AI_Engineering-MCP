# ============================================================================
# Python Core & Environments
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual Environments (Standard, uv, poetry, pipenv)
.venv/
venv/
ENV/
env/
.env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Model Context Protocol (MCP) & Local AI Configs
# ============================================================================
# Local Claude Desktop / LLM client configuration test dumps
claude_desktop_config.json
.mcp/

# Local database/vector cache storage if your MCP server provides data tools
*.db
*.sqlite
.chroma/

# Logs generated by runtime server connections or debugging transport flags
*.log
mcp-server.log
mcp-client.log

# ============================================================================
# Security & Credentials
# ============================================================================
# Block API keys (OpenAI, Anthropic, Gemini, etc.) and environment variables
.env
.env.local
.env.*
.secrets
*.pem
*.key

# ============================================================================
# Package Managers (Optional rule adjustments)
# ============================================================================
# If using uv, poetry, or pipenv, lockfiles are generally committed for apps.
# Uncomment the following if you explicitly want to ignore them:
# poetry.lock
# uv.lock
# Pipfile.lock

# ============================================================================
# IDEs and Editors
# ============================================================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace

# Cursor AI Editor
.cursorrules

# PyCharm / IntelliJ
.idea/

# OS generated
.DS_Store
Thumbs.db
